{
  "name": "@grapity/cli",
  "version": "0.0.1",
  "description": "Grapity CLI - API spec registry management from the command line",
  "license": "Apache-2.0",
  "bin": {
    "grapity": "./bin/grapity"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist", "bin"],
  "scripts": {
    "build": "tsup",
    "dev": "bun run src/index.ts",
    "typecheck": "tsc --noEmit",
    "test": "bun test"
  },
  "dependencies": {
    "@grapity/core": "link:@grapity/core",
    "commander": "^13.1.0",
    "js-yaml": "^4.1.0",
    "chalk": "^5.4.0",
    "ora": "^8.2.0"
  },
  "peerDependencies": {
    "@grapity/registry": "link:@grapity/registry"
  },
  "peerDependenciesMeta": {
    "@grapity/registry": {
      "optional": true
    }
  },
  "devDependencies": {
    "@grapity/registry": "link:@grapity/registry",
    "tsup": "^8.4.0",
    "typescript": "^5.8.0"
  }
}