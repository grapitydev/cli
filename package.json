{
  "name": "@grapity/cli",
  "version": "0.3.0",
  "type": "module",
  "description": "Grapity CLI - API spec registry management from the command line",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/grapitydev/cli"
  },
  "bin": {
    "grapity": "./bin/grapity"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "bin"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "bun run src/index.ts",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "prepublishOnly": "bun run build"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "dependencies": {
    "@grapity/core": "^0.1.0",
    "commander": "^13.1.0",
    "js-yaml": "^4.1.0",
    "chalk": "^5.4.0",
    "ora": "^8.2.0"
  },
  "peerDependencies": {
    "@grapity/registry": "^0.2.1"
  },
  "peerDependenciesMeta": {
    "@grapity/registry": {
      "optional": true
    }
  },
  "devDependencies": {
    "@grapity/registry": "0.2.1",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.0.0",
    "tsup": "^8.4.0",
    "typescript": "^5.8.0"
  }
}